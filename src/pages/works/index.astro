---
import { getCollection } from 'astro:content';
import { Picture } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { ogImageUrl } from '../../lib/og';

const series = (await getCollection('works')).sort((a, b) => a.data.order - b.data.order);
const first = series[0];
const ogImage = first?.data.photos[0]?.src
  ? await ogImageUrl(first.data.photos[0].src, Astro.site)
  : undefined;
const description = first
  ? `${first.data.title}, ${first.data.year}${first.data.intro ? ` — ${first.data.intro}` : ''}`
  : 'Photo series by Doohee Lee.';
---

<Base
  title={first ? `${first.data.title} — Doohee Lee` : 'Works — Doohee Lee'}
  description={description}
  ogImage={ogImage}
  ogType="article"
>
  {
    first ? (
      <section class="series">
        <header class="series-head">
          <h1 class="title">{first.data.title}</h1>
          <span class="year muted">{first.data.year}</span>
          {first.data.intro && <p class="intro muted">{first.data.intro}</p>}
        </header>

        {first.data.photos.length === 0 ? (
          <p class="muted empty">Photographs coming soon.</p>
        ) : (
          <div class="library">
            {first.data.photos.map((p, i) => (
              <figure class="figure">
                <Picture
                  src={p.src}
                  alt={p.caption ?? first.data.title}
                  formats={['avif', 'webp']}
                  widths={[800, 1280, 1920, 2560]}
                  sizes="(min-width: 1024px) 60vw, 100vw"
                  quality={82}
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
                {(p.title || p.caption) && (
                  <figcaption>
                    {p.title && <span class="ph-title">{p.title}</span>}
                    {p.caption && <span class="ph-caption">{p.caption}</span>}
                  </figcaption>
                )}
              </figure>
            ))}
          </div>
        )}
      </section>
    ) : (
      <p class="muted">No series yet.</p>
    )
  }
</Base>

<style>
  .series {
    padding-top: 0.5rem;
  }

  .series-head {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .title {
    font-size: 1.25rem;
    font-weight: 500;
    margin: 0;
    color: var(--text);
  }

  .year {
    font-size: 0.9375rem;
  }

  .intro {
    flex-basis: 100%;
    max-width: 36rem;
    font-size: 0.9375rem;
    margin: 0.5rem 0 0;
    line-height: 1.55;
  }

  .library {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .figure {
    margin: 0;
    text-align: center;
  }

  .figure :global(img) {
    max-width: 100%;
    max-height: 80vh;
    width: auto;
    height: auto;
    margin: 0 auto;
    display: block;
  }

  .figure figcaption {
    margin-top: 0.875rem;
    text-align: left;
    font-size: 0.9375rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .ph-title {
    color: var(--text);
  }

  .ph-caption {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .empty {
    margin: 1rem 0 0;
    font-size: 0.9375rem;
  }
</style>
