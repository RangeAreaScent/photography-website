---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';

const series = (await getCollection('works')).sort((a, b) => a.data.order - b.data.order);
const first = series[0];
---

<Base title={first ? `${first.data.title} — Ryan` : 'Works — Ryan'}>
  {
    first ? (
      <section class="series">
        <header class="series-head">
          <h1 class="title">{first.data.title}</h1>
          <span class="year muted">{first.data.year}</span>
          {first.data.intro && <p class="intro muted">{first.data.intro}</p>}
        </header>

        <div class="library">
          {first.data.photos.map((p, i) => (
            <figure class="figure">
              <Image
                src={p.src}
                alt={p.caption ?? first.data.title}
                widths={[800, 1280, 1920, 2560]}
                sizes="(min-width: 1024px) 60vw, 100vw"
                quality={88}
                format="webp"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
              {p.caption && <figcaption>{p.caption}</figcaption>}
            </figure>
          ))}
        </div>
      </section>
    ) : (
      <p class="muted">No series yet.</p>
    )
  }
</Base>

<style>
  .series {
    padding-top: 0.5rem;
  }

  .series-head {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .title {
    font-size: 1.125rem;
    font-weight: 400;
    margin: 0;
    color: var(--text);
  }

  .year {
    font-size: 0.9375rem;
  }

  .intro {
    flex-basis: 100%;
    max-width: 36rem;
    font-size: 0.9375rem;
    margin: 0.5rem 0 0;
    line-height: 1.55;
  }

  .library {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .figure {
    margin: 0;
  }

  .figure figcaption {
    margin-top: 0.875rem;
    text-align: left;
    color: var(--text-muted);
    font-size: 0.9375rem;
  }
</style>
