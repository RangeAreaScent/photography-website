---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { ogImageUrl } from '../lib/og';
import portrait from '../assets/doohee.webp';

const ogImage = await ogImageUrl(portrait, Astro.site);
---

<Base
  title="About — Doohee Lee"
  description="Doohee Lee — based in Georgia, pursuing photography as a part of everyday life."
  ogImage={ogImage}
>
  <section class="about">
    <figure class="portrait">
      <Image
        src={portrait}
        alt="Doohee Lee"
        widths={[480, 800, 1200]}
        sizes="(min-width: 1024px) 32rem, 80vw"
        quality={86}
        format="webp"
      />
    </figure>

    <h1 class="name">Doohee Lee</h1>

    <div class="bio">
      <p>Based in Georgia. Pursuing photography as a part of everyday life.</p>
      <p>Drawn to stillness; longing for the natural.</p>
      <p>Music, film, and the sound of rain.</p>
      <p>Grateful that photography allows for thought.</p>
    </div>

    <ul class="links">
      <li><a href="mailto:dui0828@gmail.com">dui0828@gmail.com</a></li>
    </ul>
  </section>
</Base>

<style>
  .about {
    padding-top: 0.5rem;
    max-width: 32rem;
  }

  .portrait {
    margin: 0 0 2.5rem;
  }

  .name {
    font-size: 1.25rem;
    font-weight: 500;
    margin: 0 0 1.5rem;
    color: var(--text);
  }

  .bio {
    margin-bottom: 2.5rem;
  }

  .bio p {
    margin: 0 0 0.625rem;
    line-height: 1.7;
    color: var(--text);
  }

  .links {
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.9375rem;
    font-style: italic;
    color: var(--text-muted);
  }

  .links li + li {
    margin-top: 0.4rem;
  }

  .links a:hover {
    color: var(--text);
  }
</style>
