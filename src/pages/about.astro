---
import Base from '../layouts/Base.astro';
---

<Base title="About — Ryan" description="About Ryan and this archive.">
  <section class="about">
    <ul class="links">
      <li><a href="mailto:hello@example.com">hello@example.com</a></li>
      <li><a href="https://instagram.com" rel="me noopener">instagram</a></li>
    </ul>
  </section>
</Base>

<style>
  .about {
    padding-top: 0.5rem;
    max-width: 32rem;
  }

  .links {
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.9375rem;
    font-style: italic;
    color: var(--text-muted);
  }

  .links li + li {
    margin-top: 0.4rem;
  }

  .links a:hover {
    color: var(--text);
  }
</style>
