---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { ogImageUrl } from '../lib/og';

const monthly = (await getCollection('monthly')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const latest = monthly[0];
const fmt = latest?.data.date.toLocaleString('en-US', { year: 'numeric', month: 'long' });
const ogImage = latest ? await ogImageUrl(latest.data.photo, Astro.site) : undefined;
---

<Base
  title="Doohee Lee — Photographs"
  description={latest?.data.caption
    ? `${fmt} — ${latest.data.caption}. Photographs by Doohee Lee.`
    : 'Selected photographs and a monthly photograph by Doohee Lee.'}
  ogImage={ogImage}
>
  <section class="home">
    {
      latest && (
        <figure class="hero">
          <Image
            src={latest.data.photo}
            alt={latest.data.caption ?? fmt ?? 'Latest photograph'}
            widths={[800, 1280, 1920, 2560]}
            sizes="(min-width: 1024px) 70vw, 100vw"
            quality={88}
            format="webp"
          />
          <figcaption>
            {latest.data.caption && <p class="title">{latest.data.caption}</p>}
            <p class="when">{fmt}</p>
          </figcaption>
        </figure>
      )
    }

    <div class="intro">
      <p>
        Photographs by Doohee Lee — pursued as a part of everyday life.
        Series under <a href="/works">Works</a>, a single photograph each
        month in <a href="/monthly">Monthly</a>.
      </p>
    </div>
  </section>
</Base>

<style>
  .home {
    padding-top: 0.5rem;
  }

  .hero {
    margin: 0;
  }

  .hero figcaption {
    margin-top: 1rem;
    text-align: center;
    font-size: 0.9375rem;
  }

  .title {
    margin: 0;
    color: var(--text);
  }

  .when {
    margin: 0.25rem 0 0;
    color: var(--text-muted);
  }

  .intro {
    max-width: 30rem;
    margin: 4rem 0 0;
  }

  .intro p {
    margin: 0 0 1rem;
    line-height: 1.7;
    color: var(--text);
  }

  .intro a {
    border-bottom: 0.5px solid var(--rule);
  }

  .intro a:hover {
    border-color: var(--text);
  }
</style>
