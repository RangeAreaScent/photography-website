---
import { getCollection, render } from 'astro:content';
import { Picture } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { ogImageUrl } from '../../lib/og';

const entries = (await getCollection('monthly')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const latest = entries[0];
const fmt = latest?.data.date.toLocaleString('en-US', {
  year: 'numeric',
  month: 'long',
});
const ogImage = latest ? await ogImageUrl(latest.data.photo, Astro.site) : undefined;
const description = latest
  ? `Monthly photograph — ${fmt}${latest.data.caption ? ` · ${latest.data.caption}` : ''}.`
  : 'Monthly photographs by Doohee Lee.';

const rendered = latest ? await render(latest) : null;
const Content = rendered?.Content;
const hasNote = latest ? (latest.body ?? '').trim().length > 0 : false;
---

<Base
  title={latest ? `${fmt} — Doohee Lee` : 'Monthly — Doohee Lee'}
  description={description}
  ogImage={ogImage}
  ogType="article"
>
  {
    latest && Content ? (
      <section class="single">
        <figure class="figure">
          <Picture
            src={latest.data.photo}
            alt={latest.data.caption ?? fmt ?? 'Monthly photograph'}
            formats={['avif', 'webp']}
            widths={[800, 1280, 1920, 2560]}
            sizes="(min-width: 1024px) 70vw, 100vw"
            quality={82}
          />
          <figcaption>
            {latest.data.caption && <p class="title">{latest.data.caption}</p>}
            <p class="when">{fmt}</p>
            {hasNote && (
              <div class="note">
                <Content />
              </div>
            )}
          </figcaption>
        </figure>
      </section>
    ) : (
      <p class="muted">No monthly photographs yet.</p>
    )
  }
</Base>

<style>
  .single {
    padding-top: 0.5rem;
  }

  .figure {
    margin: 0;
  }

  .figure figcaption {
    margin-top: 1rem;
    text-align: center;
    font-size: 0.9375rem;
  }

  .title {
    margin: 0;
    color: var(--text);
  }

  .when {
    margin: 0.25rem 0 0;
    color: var(--text-muted);
  }

  .note {
    margin: 2rem auto 0;
    max-width: 28rem;
    color: var(--text);
    line-height: 1.7;
  }

  .note :global(p) {
    margin: 0 0 1rem;
  }

  .note :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
