---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const entries = (await getCollection('monthly')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const fmt = (d: Date) =>
  d.toLocaleString('en-US', { year: 'numeric', month: 'long' });
---

<Base
  title="Monthly — Doohee Lee"
  description="A single photograph each month by Doohee Lee."
>
  <section class="monthly-index">
    <h1 class="title">Monthly</h1>

    <ol>
      {
        entries.map((m) => (
          <li>
            <a href={`/monthly/${m.id}`} class="row">
              <span class="when">{fmt(m.data.date)}</span>
              {m.data.caption && <span class="caption muted">{m.data.caption}</span>}
            </a>
          </li>
        ))
      }
    </ol>

    {entries.length === 0 && <p class="muted">No monthly photographs yet.</p>}
  </section>
</Base>

<style>
  .monthly-index {
    padding-top: 0.5rem;
    max-width: 40rem;
  }

  .title {
    font-size: 1.25rem;
    font-weight: 500;
    margin: 0 0 1.75rem;
    color: var(--text);
  }

  ol {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .row {
    display: flex;
    align-items: baseline;
    gap: 0.875rem;
    padding: 0.35rem 0;
    transition: opacity 120ms ease;
    font-size: 0.9375rem;
  }

  .row:hover {
    opacity: 0.55;
  }

  .when {
    color: var(--text);
  }

  .caption {
    font-size: 0.875rem;
  }
</style>
