---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';

const entries = (await getCollection('monthly')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const latest = entries[0];
const fmt = latest?.data.date.toLocaleString('en-US', {
  year: 'numeric',
  month: 'long',
});
---

<Base title={latest ? `${fmt} — Ryan` : 'Monthly — Ryan'}>
  {
    latest ? (
      <section class="single">
        <figure class="figure">
          <Image
            src={latest.data.photo}
            alt={latest.data.caption ?? fmt ?? 'Monthly photograph'}
            widths={[800, 1280, 1920, 2560]}
            sizes="(min-width: 1024px) 60vw, 100vw"
            quality={88}
            format="webp"
          />
          <figcaption>
            <span class="when">{fmt}</span>
            {latest.data.caption && <span class="cap">  ·  {latest.data.caption}</span>}
          </figcaption>
        </figure>
      </section>
    ) : (
      <p class="muted">No monthly photographs yet.</p>
    )
  }
</Base>

<style>
  .single {
    padding-top: 0.5rem;
  }

  .figure {
    margin: 0;
  }

  .figure figcaption {
    margin-top: 0.875rem;
    text-align: left;
    color: var(--text-muted);
    font-size: 0.9375rem;
  }

  .when {
    color: var(--text);
  }
</style>
