---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { Picture } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { ogImageUrl } from '../../lib/og';

export async function getStaticPaths() {
  const entries = await getCollection('monthly');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'monthly'>;
}

const { entry } = Astro.props;
const fmt = entry.data.date.toLocaleString('en-US', {
  year: 'numeric',
  month: 'long',
});
const ogImage = await ogImageUrl(entry.data.photo, Astro.site);
const description = `Monthly photograph — ${fmt}${entry.data.caption ? ` · ${entry.data.caption}` : ''}.`;

const { Content } = await render(entry);
const hasNote = (entry.body ?? '').trim().length > 0;
---

<Base
  title={`${fmt} — Doohee Lee`}
  description={description}
  ogImage={ogImage}
  ogType="article"
>
  <section class="single">
    <figure class="figure">
      <Picture
        src={entry.data.photo}
        alt={entry.data.caption ?? fmt}
        formats={['avif', 'webp']}
        widths={[800, 1280, 1920, 2560]}
        sizes="(min-width: 1024px) 70vw, 100vw"
        quality={82}
      />
      <figcaption>
        {entry.data.caption && <p class="title">{entry.data.caption}</p>}
        <p class="when">{fmt}</p>
        {hasNote && (
          <div class="note">
            <Content />
          </div>
        )}
      </figcaption>
    </figure>
  </section>
</Base>

<style>
  .single {
    padding-top: 0.5rem;
  }

  .figure {
    margin: 0;
  }

  .figure figcaption {
    margin-top: 1rem;
    text-align: center;
    font-size: 0.9375rem;
  }

  .title {
    margin: 0;
    color: var(--text);
  }

  .when {
    margin: 0.25rem 0 0;
    color: var(--text-muted);
  }

  .note {
    margin: 2rem auto 0;
    max-width: 28rem;
    color: var(--text);
    line-height: 1.7;
  }

  .note :global(p) {
    margin: 0 0 1rem;
  }

  .note :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
