---
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { ogImageUrl } from '../../lib/og';

export async function getStaticPaths() {
  const entries = await getCollection('monthly');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'monthly'>;
}

const { entry } = Astro.props;
const fmt = entry.data.date.toLocaleString('en-US', {
  year: 'numeric',
  month: 'long',
});
const ogImage = await ogImageUrl(entry.data.photo, Astro.site);
const description = `Monthly photograph — ${fmt}${entry.data.caption ? ` · ${entry.data.caption}` : ''}.`;
---

<Base
  title={`${fmt} — Ryan`}
  description={description}
  ogImage={ogImage}
  ogType="article"
>
  <section class="single">
    <figure class="figure">
      <Image
        src={entry.data.photo}
        alt={entry.data.caption ?? fmt}
        widths={[800, 1280, 1920, 2560]}
        sizes="(min-width: 1024px) 70vw, 100vw"
        quality={88}
        format="webp"
      />
      <figcaption>
        <span class="when">{fmt}</span>
        {entry.data.caption && <span class="cap">  ·  {entry.data.caption}</span>}
      </figcaption>
    </figure>
  </section>
</Base>

<style>
  .single {
    padding-top: 0.5rem;
  }

  .figure {
    margin: 0;
  }

  .figure figcaption {
    margin-top: 0.875rem;
    text-align: left;
    color: var(--text-muted);
    font-size: 0.9375rem;
  }

  .when {
    color: var(--text);
  }
</style>
